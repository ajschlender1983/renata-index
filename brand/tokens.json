{
  "name": "Renata brand tokens",
  "surfaces": {
    "paper": "#F4F2EC",
    "paper2": "#F7F6F2",
    "card": "#FFFFFF",
    "ink": "#16161F",
    "inkSoft": "#5A5A6A",
    "line": "#E4E1D8"
  },
  "brandAndState": {
    "violet": "#574FC7",
    "violetLight": "#8B83F0",
    "violetDeep": "#4A42B8",
    "violetInk": "#332C8A",
    "teal": "#0F7256",
    "amber": "#8A5A0C",
    "alert": "#A6342E"
  },
  "type": {
    "display": "Newsreader, Georgia, serif",
    "ui": "Inter, system-ui, sans-serif",
    "mono": "IBM Plex Mono, monospace"
  },
  "mark": {
    "viewBox": "0 0 100 100",
    "minSizePx": 16,
    "clearSpaceXHeight": 0.5,
    "lockupGapCapHeight": 0.35
  },
  "states": {
    "present":   { "color": "#574FC7", "motion": "still" },
    "listening": { "color": "#574FC7", "motion": "breath" },
    "working":   { "color": "#574FC7", "motion": "throb" },
    "found":     { "color": "#0F7256", "motion": "pop" },
    "timing":    { "color": "#8A5A0C", "motion": "breath-slow" },
    "alert":     { "color": "#A6342E", "motion": "double-pulse" }
  }
}
